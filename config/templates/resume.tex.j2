\documentclass[11pt,a4paper]{article}
\usepackage[margin=0.55in]{geometry}
\usepackage[hidelinks]{hyperref}
\usepackage{titlesec}
\usepackage{enumitem}
\titleformat{\section}{\large\bfseries}{}{0pt}{}[\titlerule]
\titlespacing*{\section}{0pt}{6pt}{3pt}
\setlist[itemize]{leftmargin=*,nosep,topsep=1pt}
\setlength{\parskip}{2pt}
\setlength{\parindent}{0pt}
\linespread{0.98}
\pagestyle{empty}

\begin{document}

\begin{center}
  {\LARGE \textbf{<< resume.contact.name | tex_escape >>}}\\[2pt]
  << resume.contact.email | tex_escape >>(* if resume.contact.phone *) $\cdot$ << resume.contact.phone | tex_escape >>(* endif *)(* if resume.contact.location *) $\cdot$ << resume.contact.location | tex_escape >>(* endif *)\\
  (* if resume.contact.github *)<< resume.contact.github | tex_escape >>(* endif *)(* if resume.contact.linkedin *) $\cdot$ << resume.contact.linkedin | tex_escape >>(* endif *)(* if resume.contact.website *) $\cdot$ << resume.contact.website | tex_escape >>(* endif *)
\end{center}

\noindent\textit{Target role:} \textbf{<< resume.role.label | tex_escape >>}

\section*{Summary}
<< resume.summary | tex_escape >>

(* if resume.skills *)
\section*{Skills}
<< resume.skills | join(" $\\cdot$ ") | tex_escape >>
(* endif *)

(* if resume.experience *)
\section*{Experience}
(* for x in resume.experience *)
\textbf{<< x.role | tex_escape >>} --- << x.company | tex_escape >>(* if x.location *), << x.location | tex_escape >>(* endif *)(* if x.start or x.end *) \hfill \textit{<< (x.start or "") | tex_escape >> -- << (x.end or "Present") | tex_escape >>}(* endif *)
(* if x.bullets *)
\begin{itemize}
(* for b in x.bullets *)
  \item << b | tex_escape >>
(* endfor *)
\end{itemize}
(* endif *)
(* endfor *)
(* endif *)

(* if resume.projects *)
\section*{Projects}
(* for p in resume.projects *)
\textbf{<< p.name | tex_escape >>}(* if p.url *) --- \href{<< p.url >>}{<< p.url | tex_escape >>}(* endif *)\\
<< p.description | tex_escape >>
(* if p.bullets *)
\begin{itemize}
(* for b in p.bullets *)
  \item << b | tex_escape >>
(* endfor *)
\end{itemize}
(* endif *)
(* if p.tech *)
\textit{Tech: << p.tech | join(", ") | tex_escape >>}
(* endif *)
\\[2pt]
(* endfor *)
(* endif *)

(* if resume.achievements *)
\section*{Achievements}
\begin{itemize}
(* for a in resume.achievements *)
  \item \textbf{<< a.title | tex_escape >>}(* if a.date *) \textit{(<< a.date | tex_escape >>)}(* endif *) --- \textit{<< a.source | tex_escape >>}(* if a.snippet *): << a.snippet | tex_escape >>(* endif *)
(* endfor *)
\end{itemize}
(* endif *)

(* if resume.certifications *)
\section*{Certifications}
\begin{itemize}
(* for c in resume.certifications *)
  \item \textbf{<< c.name | tex_escape >>}(* if c.issuer *) --- << c.issuer | tex_escape >>(* endif *)(* if c.date *) (<< c.date | tex_escape >>)(* endif *)
(* endfor *)
\end{itemize}
(* endif *)

(* if resume.education *)
\section*{Education}
(* for e in resume.education *)
\textbf{<< e.school | tex_escape >>}(* if e.degree *) --- << e.degree | tex_escape >>(* endif *)(* if e.field *) in << e.field | tex_escape >>(* endif *)(* if e.start or e.end *) \hfill \textit{<< (e.start or "") | tex_escape >> -- << (e.end or "") | tex_escape >>}(* endif *)
(* if e.notes *)
\begin{itemize}
(* for n in e.notes *)
  \item << n | tex_escape >>
(* endfor *)
\end{itemize}
(* endif *)
(* endfor *)
(* endif *)

\end{document}
