# LLM provider configuration (only required for AI mode)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Production model boundary: always call an HTTP API. The same OpenAI-compatible
# contract supports a cloud endpoint or a locally hosted model server.
# One of: openai-compatible | openai | anthropic | null
RESUME_LLM_PROVIDER=openai-compatible
RESUME_LLM_API_BASE_URL=https://api.openai.com/v1
RESUME_LLM_API_KEY=
RESUME_LLM_MODEL=gpt-4o-mini

# Default model per provider
RESUME_ANTHROPIC_MODEL=claude-sonnet-4-6
RESUME_OPENAI_MODEL=gpt-4o-mini

# GitHub user/org to scan (override via CLI --gh-user)
RESUME_GH_USER=
# Product default: scrape the normal GitHub website. "cli" is developer convenience only.
RESUME_GITHUB_SOURCE=website

# Override config directory (defaults to ./config)
RESUME_CONFIG_DIR=

# Web OAuth for Dashboard identity login.
# Create provider apps first, then paste the values here or set them in PowerShell.
CAREERLENS_BASE_URL=http://127.0.0.1:8010

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
